{
  "general": {
    "checkpointing": {
      "enabled": true
    },
    "preferredEditor": "antigravity",
    "vimMode": false,
    "previewFeatures": true,
    "enablePromptCompletion": false,
    "disableAutoUpdate": true,
    "enableAutoUpdate": false
  },
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "$CONTEXT7_API_KEY"
      ]
    },
    "dart": {
      "command": "dart",
      "args": [
        "mcp-server"
      ]
    }
  },
  "mcp": {
    "excluded": []
  },
  "ui": {
    "showLineNumbers": true,
    "showCitations": true,
    "customThemes": {
      "lcarv": {
        "name": "lcarv",
        "type": "custom",
        "Background": "#262626",
        "Foreground": "#ffecb1",
        "LightBlue": "#ffd489",
        "AccentBlue": "#ff8c69",
        "AccentPurple": "#ff7044",
        "AccentCyan": "#fec28d",
        "AccentGreen": "#ffe79f",
        "AccentYellow": "#ffce86",
        "AccentRed": "#ff662e",
        "Gray": "#d0a46a",
        "Comment": "#bdb54d",
        "DiffAdded": "#12331b",
        "DiffRemoved": "#422219",
        "GradientColors": [
          "#4796E4",
          "#847ACE",
          "#C3677F"
        ]
      }
    },
    "theme": "Dracula",
    "footer": {
      "hideContextPercentage": false
    },
    "showModelInfoInChat": true,
    "useFullWidth": true
  },
  "ide": {
    "enabled": true
  },
  "tools": {
    "sandbox": false,
    "shell": {
      "showColor": true
    },
    "useRipgrep": true
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "folderTrust": {
      "enabled": true
    }
  },
  "privacy": {
    "usageStatisticsEnabled": true
  },
  "output": {
    "format": "text"
  }
}