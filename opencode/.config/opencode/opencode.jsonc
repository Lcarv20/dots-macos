{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-oss-20b",
  "permission": {
    "edit": "ask",
    "write": "ask",
    "bash": {
      "*": "ask",
      "ls": "allow",
      "pwd": "allow",
      "date": "allow",
      "fd*": "allow",
      "rg*": "allow",
      "cat*": "allow",
      "head*": "allow",
      "tail*": "allow",
      "grep*": "allow",
      "find*": "allow",
      "echo*": "allow",
      "stat*": "allow",
      "which*": "allow",
      "git status": "allow",
      "git diff*": "allow",
      "git branch": "allow",
      "git log": "allow"
    }
  },
  "tools": {
    "webfetch": true
  },
  "plugin": [
    "opencode-gemini-auth@latest"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "mgrep": {
      "type": "local",
      "command": [
        "mgrep",
        "mcp"
      ]
    }
  },
  "agent": {
    "plan": {
      "mode": "primary",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "permission": {
        "write": "ask",
        "edit": "ask",
        "bash": "ask"
      }
    },
    "build": {
      "mode": "primary",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "permission": {
        "write": "ask",
        "edit": "ask",
        "bash": {
          "*": "ask",
          "ls": "allow",
          "pwd": "allow",
          "git status": "allow",
          "git diff*": "allow"
        }
      }
    },
    "autoaccept": {
      "mode": "primary",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "permission": {
        "edit": "allow",
        "write": "allow",
        "bash": {
          "*": "ask", // Forces asking for everything else (like commit)
          "ls": "allow",
          "pwd": "allow",
          "git status": "allow",
          "git diff*": "allow"
        }
      }
    },
    "yolo": {
      "mode": "primary",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "permission": {
        "edit": "allow",
        "write": "allow",
        "bash": {
          "*": "allow",
          "rm -rf /": "deny",
          "rm -rf *": "deny",
          "mkfs*": "deny"
        }
      }
    }
  }
}
