{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-oss-20b",
  "permission": {
    "edit": "ask",
    "write": "ask",
    "bash": {
      "*": "ask",
      "ls": "allow",
      "pwd": "allow",
      "git status": "allow",
      "git diff*": "allow",
      "git add*": "allow",
      "git log*": "allow"
    }
  },
  "tools": {
    "webfetch": true
  },
  "plugin": [
    "opencode-gemini-auth@latest"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "mgrep": {
      "type": "local",
      "command": [
        "mgrep",
        "mcp"
      ]
    }
  },
  "agent": {
    "plan": {
      "mode": "primary",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "permission": {
        "write": "ask",
        "edit": "ask",
        "bash": "ask" // Overrides global: even 'ls' requires permission in Plan
      }
    },
    "build": {
      "mode": "primary",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "permission": {
        "write": "ask", // Explicitly added so it stops writing without asking
        "edit": "ask"
        // Bash is omitted here so it inherits your global "safe" list
      }
    },
    "autoaccept": {
      "mode": "primary",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "permission": {
        "edit": "allow",
        "write": "allow"
        // Inherits global bash: 'ls' is allowed, others are 'ask'
      }
    },
    "yolo": {
      "mode": "primary",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "permission": {
        "edit": "allow",
        "write": "allow",
        "bash": {
          "*": "allow", // Wildcard FIRST
          "rm -rf /": "deny", // Specific blocks LAST so they win
          "rm -rf *": "deny",
          "mkfs*": "deny"
        }
      }
    },
  }
}
